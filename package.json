{
  "name": "promiedos-collapser",
  "version": "1.0.0",
  "description": "Browser extension to persist collapsed tournaments on promiedos.com.ar",
  "private": true,
  "scripts": {
    "build": "vite build",
    "check": "npm-run-all typecheck test build",
    "dev": "vite build --watch",
    "package": "npm run build && cd dist && zip -r ../promiedos-collapser.zip .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.1",
    "@types/webextension-polyfill": "^0.12.5",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "packageManager": "pnpm@11.3.0"
}
